<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/m3_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- ─── Stepper ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">

        <!-- Step 1 -->
        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp">
            <View
                android:id="@+id/stepDot1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_shape"
                android:backgroundTint="@color/m3_primary" />
            <TextView
                android:id="@+id/stepText1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textSize="12sp"
                android:textColor="@color/m3_on_primary"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Tag 1"
            android:textSize="13sp"
            android:textColor="@color/m3_on_surface"
            android:fontFamily="sans-serif-medium" />

        <!-- Connector line -->
        <View
            android:id="@+id/stepConnector"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/m3_surface_container_high"
            android:backgroundTint="@color/m3_surface_container_high" />

        <!-- Step 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Tag 2"
            android:textSize="13sp"
            android:textColor="@color/m3_on_surface_variant"
            android:fontFamily="sans-serif-medium"
            android:id="@+id/stepLabel2" />

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp">
            <View
                android:id="@+id/stepDot2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_shape"
                android:backgroundTint="@color/m3_surface_container_highest" />
            <TextView
                android:id="@+id/stepText2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="2"
                android:textSize="12sp"
                android:textColor="@color/m3_on_surface_variant"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

    </LinearLayout>

    <!-- ─── NFC pulse illustration ─── -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/m3_primary"
            android:alpha="0.10" />

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/m3_primary"
            android:alpha="0.15" />

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/m3_primary"
            android:alpha="0.22" />

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/rounded_card_background"
            android:backgroundTint="@color/m3_primary"
            android:elevation="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/twotone_nfc_24"
                app:tint="@color/m3_on_primary" />

        </FrameLayout>

    </FrameLayout>

    <!-- ─── Instruction text ─── -->
    <TextView
        android:id="@+id/txtInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center"
        android:textColor="@color/m3_on_surface"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.3"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <!-- ─── Actions ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="@string/cancel" />

        <Button
            android:id="@+id/btnWriteTag"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:text="@string/write_tag_1"
            app:icon="@drawable/twotone_nfc_24" />

    </LinearLayout>

</LinearLayout>
