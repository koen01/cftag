<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/m3_surface"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="4dp"
            android:paddingBottom="4dp"
            android:text="@string/choose_action_title"
            android:textSize="22sp"
            android:textColor="@color/m3_on_surface"
            android:fontFamily="sans-serif-medium" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="4dp"
            android:paddingBottom="16dp"
            android:text="@string/choose_action_subtitle"
            android:textSize="14sp"
            android:textColor="@color/m3_on_surface_variant" />

        <!-- PATH A: Create new spool (primary bg) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/m3_primary"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Icon -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/m3_on_primary"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/twotone_add_24"
                        app:tint="@color/m3_primary" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_action_path_a_label"
                    android:textSize="12sp"
                    android:textColor="@color/m3_on_primary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/choose_action_path_a_headline"
                    android:textSize="22sp"
                    android:textColor="@color/m3_on_primary"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/choose_action_path_a_body"
                    android:textSize="14sp"
                    android:textColor="@color/m3_on_primary"
                    android:alpha="0.9" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnCreateSpool"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:backgroundTint="@color/m3_on_primary"
                        app:cornerRadius="20dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Continue"
                        android:textColor="@color/m3_primary"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OR divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/m3_outline_variant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="OR"
                android:textSize="12sp"
                android:textColor="@color/m3_on_surface_variant"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/m3_outline_variant" />

        </LinearLayout>

        <!-- PATH B: Link existing spool (surface high bg) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/m3_surface_container_high"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Icon -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/m3_tertiary_container"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/twotone_contactless_24"
                        app:tint="@color/m3_on_tertiary_container" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_action_path_b_label"
                    android:textSize="12sp"
                    android:textColor="@color/m3_primary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/choose_action_path_b_headline"
                    android:textSize="22sp"
                    android:textColor="@color/m3_on_surface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/choose_action_path_b_body"
                    android:textSize="14sp"
                    android:textColor="@color/m3_on_surface_variant" />

                <!-- Spool picker -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/m3_surface"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginEnd="12dp"
                                android:importantForAccessibility="no"
                                app:srcCompat="@drawable/twotone_contactless_24"
                                app:tint="@color/m3_on_surface_variant" />

                            <TextView
                                android:id="@+id/txtChosenSpool"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/spoolman_spinner_label"
                                android:textSize="14sp"
                                android:textColor="@color/m3_on_surface_variant" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:importantForAccessibility="no"
                                app:srcCompat="@drawable/ic_arrow_down"
                                app:tint="@color/m3_on_surface_variant" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <Spinner
                        android:id="@+id/chooseActionSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:spinnerMode="dialog"
                        android:background="@null"
                        android:alpha="0.01" />

                </FrameLayout>

                <Button
                    android:id="@+id/btnLinkSpool"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/btn_browse_spools" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cancel -->
        <Button
            android:id="@+id/btnCancelChoose"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@android:string/cancel" />

    </LinearLayout>
</ScrollView>
