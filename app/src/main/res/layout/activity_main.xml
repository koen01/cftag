<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="end">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/m3_surface"
        android:fitsSystemWindows="true"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxWidth="500dp"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="80dp"
            tools:context=".MainActivity">

            <!-- ═══ EXPRESSIVE TOP APP BAR ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/menubutton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/twotone_menu_24"
                    app:tint="@color/m3_on_surface" />

                <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <ImageView
                    android:id="@+id/deletebutton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/twotone_delete_24"
                    app:tint="@color/m3_on_surface_variant" />

                <ImageView
                    android:id="@+id/editbutton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/twotone_edit_24"
                    app:tint="@color/m3_on_surface_variant" />

                <ImageView
                    android:id="@+id/addbutton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/twotone_add_24"
                    app:tint="@color/m3_on_surface_variant" />

            </LinearLayout>

            <!-- Large title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="28sp"
                    android:textColor="@color/m3_on_surface"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Creality RFID spool tags"
                    android:textSize="14sp"
                    android:textColor="@color/m3_on_surface_variant" />

            </LinearLayout>

            <!-- ═══ NFC HERO CARD ═══ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/m3_hero_gradient"
                android:clipToOutline="true">

                <!-- Decorative rings (top-right) -->
                <ImageView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-30dp"
                    android:layout_marginEnd="-30dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/m3_nfc_rings" />

                <!-- Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/twotone_nfc_24"
                            app:tint="@color/m3_on_primary_container" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="WAITING FOR TAG"
                            android:textSize="12sp"
                            android:textColor="@color/m3_on_primary_container"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tagid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_00_00_00_00"
                        android:textSize="22sp"
                        android:textColor="@color/m3_on_primary_container"
                        android:fontFamily="monospace"
                        android:fontWeight="500" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/lbltagid"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tap an RFID tag to the back of your phone"
                            android:textSize="12sp"
                            android:textColor="@color/m3_on_primary_container"
                            android:alpha="0.8" />

                    </LinearLayout>

                    <!-- readbutton kept hidden for binding compat -->
                    <Button
                        android:id="@+id/readbutton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                </LinearLayout>
            </FrameLayout>

            <!-- ═══ FILAMENT SECTION LABEL ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp"
                android:text="FILAMENT"
                android:textSize="12sp"
                android:textColor="@color/m3_primary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12" />

            <!-- ═══ FILAMENT GROUP CARD ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/m3_surface_container_low"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Printer -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/printer">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Brand -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/brand">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/brand"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Type -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/type">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/material"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Size -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/size">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/spoolsize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Color row -->
                    <LinearLayout
                        android:id="@+id/colorRow"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/color"
                            android:textSize="14sp"
                            android:textColor="@color/m3_on_surface_variant" />

                        <View
                            android:id="@+id/colorview"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/txtcolor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#000000"
                            android:textSize="14sp"
                            android:textColor="@color/m3_on_surface"
                            android:fontFamily="monospace" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_arrow_down"
                            app:tint="@color/m3_on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ SPOOLMAN SECTION ═══ -->
            <LinearLayout
                android:id="@+id/spoolman_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp"
                    android:text="SPOOLMAN"
                    android:textSize="12sp"
                    android:textColor="@color/m3_primary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12" />

                <!-- Single CTA: opens the choose-action dialog -->
                <Button
                    android:id="@+id/btnContinue"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    app:cornerRadius="28dp"
                    android:text="@string/btn_continue_spoolman"
                    android:textSize="16sp"
                    app:icon="@drawable/twotone_nfc_24"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/btn_continue_spoolman_subtitle"
                    android:textSize="12sp"
                    android:textColor="@color/m3_on_surface_variant" />

                <!-- Hidden binding-compat views (never shown) -->
                <Button
                    android:id="@+id/btnWriteAndCreate"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnLinkExisting"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <Spinner
                    android:id="@+id/spoolmanSpinner"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Legacy hidden views kept for binding compatibility -->
            <Button
                android:id="@+id/writebutton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:text="@string/write" />

            <TextView
                android:id="@+id/txtmsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FA6F6F"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="false"
        android:theme="@style/Theme.MaterialComponents.DayNight"
        app:itemTextAppearance="@style/NavigationDrawerText"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/activity_main_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
